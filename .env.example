# === 智演助手 环境变量配置 ===
# 复制此文件为 .env 并填入实际值

# --- API 密钥 ---
ARK_API_KEY=your_ark_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- ARK 端点 ID（从火山引擎控制台获取）---
SEEDREAM_ENDPOINT=your_seedream_endpoint
SEEDANCE_ENDPOINT=your_seedance_endpoint

# --- Pexels API（素材爬取用）---
PEXELS_API_KEY=your_pexels_api_key_here

# --- 运行环境 ---
FLASK_ENV=development

# --- 访问控制（生产环境必须设置）---
# ACCESS_TOKEN=your_secure_token_here

# --- MySQL（clip_trends 模块用）---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=clip_trends
MYSQL_USER=clip_trends
MYSQL_PASSWORD=your_mysql_password
